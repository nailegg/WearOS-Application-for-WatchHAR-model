# Normalize text files to LF in the repository.
* text=auto

*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.pro text eol=lf

# ML/data/model assets must never receive line-ending conversion.
*.tflite binary
*.h5 binary
*.keras binary
*.weights.h5 binary
*.npy binary
*.npz binary
*.pkl binary
*.zip binary

# Android/image/runtime binaries.
*.jar binary
*.webp binary
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
